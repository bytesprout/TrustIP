{
  "name": "@trustip/dataset-updater",
  "version": "1.0.0",
  "description": "TrustIP Dataset Updater Engine — downloads, validates, hot-reloads GeoLite2/Tor/FireHOL/VPN datasets",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsup src/index.ts --format cjs --dts",
    "dev": "tsup src/index.ts --format cjs --dts --watch",
    "test": "jest --passWithNoTests",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@nestjs/bullmq": "^10.2.3",
    "@nestjs/common": "^10.4.15",
    "@nestjs/core": "^10.4.15",
    "@nestjs/event-emitter": "^2.1.1",
    "@prisma/client": "^5.22.0",
    "@trustip/shared-config": "workspace:*",
    "bullmq": "^5.34.8",
    "ioredis": "^5.4.2",
    "maxmind": "^4.3.21",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/testing": "^10.4.15",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.6",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "tsup": "^8.4.0",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "@nestjs/common": "^10.x",
    "@nestjs/core": "^10.x"
  },
  "jest": {
    "moduleFileExtensions": ["js", "json", "ts"],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": ["**/*.(t|j)s"],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  },
  "license": "UNLICENSED"
}
