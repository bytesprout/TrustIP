# Application
APP_NAME=TrustIP
APP_ENV=development
APP_MODE=saas
APP_PORT=8080
APP_URL=http://localhost:8080

# Database
DATABASE_URL=postgresql://trustip:trustip_dev_password@postgres:5432/trustip_db

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis_dev_password
REDIS_URL=redis://:redis_dev_password@redis:6379

# JWT
JWT_SECRET=change_this_to_a_very_long_random_secret_minimum_64_chars_xxxxxxxxxxxxxxxx
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Admin App
ADMIN_URL=http://localhost:3000
NEXTAUTH_SECRET=change_this_nextauth_secret_minimum_32_chars_xxxxxxxx
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8080

# Security / Abuse Monitoring
SECURITY_ABUSE_WINDOW_SECONDS=300
SECURITY_ABUSE_THRESHOLD=8
SECURITY_BLOCK_SECONDS=900

# OpenTelemetry (optional collector endpoint)
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
